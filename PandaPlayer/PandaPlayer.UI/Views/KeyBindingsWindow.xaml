<Window x:Class="PandaPlayer.UI.Views.KeyBindingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keyboard Shortcuts" Height="460" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E" Foreground="#E8E8E8" FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="BrBg"      Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BrPanel"   Color="#252525"/>
        <SolidColorBrush x:Key="BrControl" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="BrHover"   Color="#383838"/>
        <SolidColorBrush x:Key="BrAccent"  Color="#0078D4"/>
        <SolidColorBrush x:Key="BrText"    Color="#E8E8E8"/>
        <SolidColorBrush x:Key="BrTextSec" Color="#909090"/>
        <SolidColorBrush x:Key="BrBorder"  Color="#3A3A3A"/>

        <!-- Flat button for Cancel/Reset -->
        <Style x:Key="DkBtn" TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource BrControl}"/>
            <Setter Property="Foreground"       Value="{StaticResource BrText}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="14,6"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button for Close -->
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource DkBtn}">
            <Setter Property="Background"  Value="{StaticResource BrAccent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrAccent}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1082D5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#006CBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"              Value="{StaticResource BrPanel}"/>
            <Setter Property="Foreground"              Value="{StaticResource BrText}"/>
            <Setter Property="BorderBrush"             Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="RowBackground"           Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#272727"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BrBorder}"/>
            <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
            <Setter Property="SelectionMode"           Value="Single"/>
            <Setter Property="GridLinesVisibility"     Value="Horizontal"/>
            <Setter Property="HeadersVisibility"       Value="Column"/>
            <Setter Property="CanUserAddRows"          Value="False"/>
            <Setter Property="CanUserDeleteRows"       Value="False"/>
            <Setter Property="CanUserResizeRows"       Value="False"/>
            <Setter Property="FocusVisualStyle"        Value="{x:Null}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{StaticResource BrControl}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrTextSec}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="12,7"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="SeparatorBrush"  Value="{StaticResource BrBorder}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource BrText}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrHover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground"       Value="{StaticResource BrText}"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="12,6"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thin dark scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width"      Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Keyboard Shortcuts"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource BrText}"/>
            <TextBlock Text="Double-click any row to reassign its shortcut"
                       FontSize="11" Foreground="{StaticResource BrTextSec}"
                       Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Bindings grid -->
        <DataGrid Grid.Row="1" x:Name="BindingsGrid"
                  MouseDoubleClick="BindingsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ACTION" Binding="{Binding Description}"
                                    Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="SHORTCUT" Binding="{Binding}"
                                    Width="140" IsReadOnly="True" FontWeight="SemiBold"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Changes are saved automatically"
                       VerticalAlignment="Center"
                       FontSize="11" Foreground="{StaticResource BrTextSec}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Reset Defaults" Click="Reset_Click"
                        Style="{StaticResource DkBtn}" Margin="0,0,8,0"/>
                <Button Content="Close" Click="Close_Click"
                        Style="{StaticResource AccentBtn}" IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
