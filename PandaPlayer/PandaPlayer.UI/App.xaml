<Application x:Class="PandaPlayer.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>

        <!--
            Dark menu templates — must live in App.xaml, NOT Window.xaml.
            Popup windows (used by MenuItem submenus and ContextMenu) are
            separate top-level HWNDs and only inherit Application.Resources,
            not Window.Resources.
        -->

        <!-- Separator line inside any menu / context menu -->
        <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="#3A3A3A" Margin="6,3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Menu bar container -->
        <Style TargetType="{x:Type Menu}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background"  Value="#252525"/>
            <Setter Property="Foreground"  Value="#E8E8E8"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Menu}">
                        <Border Background="{TemplateBinding Background}" Padding="2,1">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- MenuItem — covers TopLevelHeader, TopLevelItem, SubmenuHeader, SubmenuItem -->
        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="#E8E8E8"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Header text -->
                                <ContentPresenter Grid.Column="0"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"/>

                                <!-- Keyboard gesture hint -->
                                <TextBlock x:Name="GestureText" Grid.Column="1"
                                           Text="{TemplateBinding InputGestureText}"
                                           Foreground="#707070"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="18,0,6,0"/>

                                <!-- Submenu arrow -->
                                <Path x:Name="Arrow" Grid.Column="2"
                                      Data="M0,0 L0,7 L4,3.5 Z"
                                      Fill="#909090"
                                      Width="4" Height="7"
                                      VerticalAlignment="Center"
                                      Margin="6,0,2,0"
                                      Visibility="Collapsed"/>

                                <!-- Submenu popup -->
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Right"
                                       HorizontalOffset="-1"
                                       PopupAnimation="Fade">
                                    <Border Background="#252525"
                                            BorderBrush="#3A3A3A"
                                            BorderThickness="1"
                                            Padding="0,3">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- TOP-LEVEL HEADER (has submenu, sits in menu bar) -->
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom"/>
                                <Setter TargetName="PART_Popup" Property="HorizontalOffset" Value="0"/>
                                <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed"/>
                            </Trigger>

                            <!-- TOP-LEVEL ITEM (no submenu, sits in menu bar) -->
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed"/>
                            </Trigger>

                            <!-- SUBMENU HEADER (has sub-popup inside a dropdown) -->
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <!-- SUBMENU ITEM (leaf node inside a dropdown) -->
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter Property="Padding" Value="10,6"/>
                            </Trigger>

                            <!-- Hover / keyboard highlight for top-level items -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsHighlighted" Value="True"/>
                                    <Condition Property="Role" Value="TopLevelHeader"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#383838"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsHighlighted" Value="True"/>
                                    <Condition Property="Role" Value="TopLevelItem"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#383838"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>

                            <!-- Hover for submenu items — accent blue highlight -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsHighlighted" Value="True"/>
                                    <Condition Property="Role" Value="SubmenuHeader"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Arrow" Property="Fill" Value="White"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsHighlighted" Value="True"/>
                                    <Condition Property="Role" Value="SubmenuItem"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="GestureText" Property="Foreground" Value="#C0D8F0"/>
                            </MultiTrigger>

                            <!-- Top-level open state (submenu is visible) -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Role" Value="TopLevelHeader"/>
                                    <Condition Property="IsSubmenuOpen" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#383838"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter TargetName="GestureText" Property="Foreground" Value="#444444"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ContextMenu -->
        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="#252525"
                                BorderBrush="#3A3A3A"
                                BorderThickness="1"
                                Padding="0,3">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
